PORT=5000
MONGO_URI=
JWT_SECRET=
BETTER_AUTH_URL=
FRONTEND_URL=
# Comma-separated list of extra allowed frontend origins for auth requests.
# Example: CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=
SERPAPI_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=
# Optional: comma-separated eBay domains for SerpAPI search priority.
# Defaults to global mix (ebay.com, ebay.de, ebay.co.uk, ebay.fr, ebay.it, ebay.es, ebay.nl)
EBAY_DOMAINS=
# Optional: force re-enrichment even when listing already has Cloudinary images.
ENRICH_FORCE=false
# Optional: when true, overwrite listing images with newly imported set instead of merging.
ENRICH_REPLACE_EXISTING=false
# Optional: minimum number of Cloudinary images before listing is considered enriched.
ENRICH_MIN_CLOUDINARY_IMAGES=3